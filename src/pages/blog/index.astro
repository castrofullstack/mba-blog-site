---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const heroImage = '/images/blog-hero.png';
---

<BaseLayout title="Blog" description="Read From Scratch essays on workflow, strategy, AI, cooking, craft, and better systems." image={heroImage}>
  <section class="page-header">
    <p class="eyebrow">The archive</p>
    <h1>Essays on making things work better.</h1>
    <p>Practical notes on workflow, strategy, AI, cooking, and craft, written for people who care about the difference between a good idea and a useful system.</p>
  </section>
  <figure class="page-visual">
    <img src={heroImage} alt="A bright business workspace with abstract planning notes and analytics" />
  </figure>
  <section class="section">
    <div class="post-grid">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </section>
</BaseLayout>
