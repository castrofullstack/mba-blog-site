---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Contact MBA Blog for collaborations, questions, speaking, or consulting inquiries.">
  <section class="page-header">
    <p class="eyebrow">Contact</p>
    <h1>Let’s start the right conversation.</h1>
    <p>For collaborations, consulting inquiries, interviews, or thoughtful notes, use the links below.</p>
  </section>
  <section class="content-band contact-grid">
    <a class="contact-card" href="mailto:hello@example.com">
      <span>Email</span>
      <strong>hello@example.com</strong>
    </a>
    <a class="contact-card" href="https://www.linkedin.com/" target="_blank" rel="noreferrer">
      <span>LinkedIn</span>
      <strong>Connect professionally</strong>
    </a>
    <a class="contact-card" href="/blog/">
      <span>Writing</span>
      <strong>Browse the latest essays</strong>
    </a>
  </section>
</BaseLayout>