---
import BaseLayout from '../layouts/BaseLayout.astro';

const heroImage = '/images/contact-hero.png';
---

<BaseLayout title="Contact" description="Contact From Scratch for collaborations, questions, speaking, or consulting inquiries." image={heroImage}>
  <section class="page-header">
    <p class="eyebrow">Contact</p>
    <h1>Let’s start the right conversation.</h1>
    <p>For collaborations, consulting inquiries, interviews, or thoughtful notes, use the links below.</p>
  </section>
  <figure class="page-visual">
    <img src={heroImage} alt="A calm executive study with strategy notes and business writing tools" />
  </figure>
  <section class="content-band contact-grid">
    <a class="contact-card" href="mailto:ChristopherCastroMBA@gmail.com">
      <span>Email</span>
      <strong>ChristopherCastroMBA@gmail.com</strong>
    </a>
    <a class="contact-card" href="https://www.linkedin.com/" target="_blank" rel="noreferrer">
      <span>LinkedIn</span>
      <strong>Connect professionally</strong>
    </a>
    <a class="contact-card" href="/blog/">
      <span>Writing</span>
      <strong>Browse the latest essays</strong>
    </a>
  </section>
</BaseLayout>
