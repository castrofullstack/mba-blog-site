---
import BaseLayout from '../layouts/BaseLayout.astro';

const heroImage = '/images/about-hero.png';
---

<BaseLayout title="About" description="Learn about From Scratch, where systems thinking meets real life in the hospital, the kitchen, and the game." image={heroImage}>
  <section class="page-header">
    <p class="eyebrow">About From Scratch</p>
    <h1>Where systems thinking meets real life.</h1>
    <p>From Scratch is where systems thinking meets real life: in the hospital, the kitchen, and the game. I'm Christopher Castro, a Workflow &amp; Usability Specialist with a background in IT and an MBA. I write about how things get built, how they break, and how to make them better.</p>
  </section>
  <figure class="page-visual">
    <img src={heroImage} alt="A refined executive workspace with abstract business planning details" />
  </figure>
  <section class="content-band two-column">
    <div>
      <h2>What this site is for</h2>
      <p>This is a place for practical notes on workflow, strategy, AI, cooking, and sport through the same first-principles lens: what is being built, what makes it work, and where the process breaks down.</p>
      <p>The voice is professional but approachable, honest about the process, and grounded in practice rather than punditry.</p>
    </div>
    <div class="callout">
      <h2>Core themes</h2>
      <ul>
        <li>The Recipe: process, workflow, and how-to</li>
        <li>The Playbook: strategy, sports, and performance</li>
        <li>The Build: tech, AI, and tools</li>
        <li>The Kitchen: cooking, creativity, and craft</li>
      </ul>
    </div>
  </section>
</BaseLayout>
