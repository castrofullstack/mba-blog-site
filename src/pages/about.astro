---
import BaseLayout from '../layouts/BaseLayout.astro';

const heroImage = '/images/about-hero.png';
---

<BaseLayout title="About" description="Learn about Christopher Castro and the point of view behind From Scratch." image={heroImage}>
  <section class="page-header">
    <p class="eyebrow">About From Scratch</p>
    <h1>Writing about how useful things get built.</h1>
    <p>I'm Christopher Castro, a Workflow &amp; Usability Specialist with a background in IT and an MBA. From Scratch is my home for practical thinking about systems, strategy, AI, cooking, and craft.</p>
  </section>
  <figure class="page-visual">
    <img src={heroImage} alt="A refined executive workspace with abstract business planning details" />
  </figure>
  <section class="content-band two-column">
    <div>
      <h2>What this site is for</h2>
      <p>This is a place to look at work from the ground up: what people are trying to do, what gets in their way, and what kind of structure helps the better version happen more often.</p>
      <p>The writing is professional, direct, and grounded in practice. It is less interested in buzzwords than in the honest mechanics of better execution.</p>
    </div>
    <div class="callout">
      <h2>Core themes</h2>
      <ul>
        <li>The Recipe: process, workflow, and repeatable improvement</li>
        <li>The Playbook: strategy, sports, and performance under pressure</li>
        <li>The Build: technology, AI, and tools worth understanding</li>
        <li>The Kitchen: cooking, creativity, and craft in motion</li>
      </ul>
    </div>
  </section>
</BaseLayout>
