---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const featured = posts.find((post) => post.data.featured) ?? posts[0];
const recentPosts = posts.filter((post) => post.id !== featured?.id).slice(0, 3);
---

<BaseLayout title="Christopher Castro, MBA" description="AI strategy, leadership, and practical thinking from Christopher Castro, MBA.">
  <section class="hero">
    <img src="/headshot-on-white.jpg" alt="Christopher Castro" />
    <div class="hero-overlay">
      <p class="eyebrow">AI strategy, leadership, and the smarter way to work</p>
      <h1>Turning complex ideas into clear, actionable thinking.</h1>
      <p class="hero-copy">Christopher Castro is an MBA, AI workflow consultant, and Lab Builder Specialist writing about artificial intelligence, strategy, operations, and the tools that help professionals work smarter.</p>
      <div class="hero-actions">
        <a class="button" href="/blog/">Read the blog</a>
        <a class="button button-secondary" href="/about/">About Christopher</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <p class="eyebrow">Featured post</p>
      <h2>Start with the most important read.</h2>
    </div>
    {featured && <PostCard post={featured} />}
  </section>

  <section class="section section-muted">
    <div class="section-heading">
      <p class="eyebrow">Latest writing</p>
      <h2>Recent posts and essays</h2>
    </div>
    <div class="post-grid">
      {recentPosts.map((post) => <PostCard post={post} />)}
    </div>
  </section>
</BaseLayout>