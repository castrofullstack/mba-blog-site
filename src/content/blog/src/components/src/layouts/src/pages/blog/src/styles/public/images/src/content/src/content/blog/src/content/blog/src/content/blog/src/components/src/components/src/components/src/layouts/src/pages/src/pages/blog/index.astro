---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="Blog" description="Read essays from MBA Blog on strategy, leadership, operations, and communication.">
  <section class="page-header">
    <p class="eyebrow">The archive</p>
    <h1>Ideas for clearer business decisions.</h1>
    <p>Short, practical essays for people who want their work to be sharper, calmer, and easier to act on.</p>
  </section>
  <section class="section">
    <div class="post-grid">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </section>
</BaseLayout>
